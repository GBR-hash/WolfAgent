# System prompts for each player role in Werewolf Game

# === Strategy sections by role and play style ===

WEREWOLF_STRATEGY = {
    "conservative": """策略风格（保守）：
- 全程伪装成普通村民，纯逻辑分析
- 不跳任何假身份，不主动带节奏，跟随他人分析
- 发言中绝对不暗示自己有信息
- 投票时随大流，不要太突出""",
    "balanced": """策略风格（均衡）：
- 第2轮起积极考虑伪装预言家或女巫
- 有人跳身份时主动对跳制造混乱——混乱对狼人有利
- 和队友配合：一个装村民、一个装神职
- 选定伪装后要坚持，不要中途变来变去""",
    "aggressive": """策略风格（激进）：
- 第1轮起主动跳假预言家/女巫，给出虚假查验信息
- 和队友配合对跳不同神职制造混乱
- 有人对跳时正面硬刚不退让
- 目标是让好人阵营彻底混乱，分不清真假神职""",
}

SEER_STRATEGY = {
    "conservative": """策略风格（保守）：
- 只在确定查到狼人时才跳身份公布结果
- 其余时间当自己是村民，纯逻辑分析
- 查到好人时保持沉默
- 被投票时才报出查验信息""",
    "balanced": """策略风格（均衡）：
- 第2轮起公布查验结果（无论查到好人狼人）
- 如果有人冒充预言家，立刻跳出来用查验链揭穿
- 跳身份时给出完整查验链：第1晚查了谁→结果，第2晚查了谁→结果
- 被投票前必须报出全部查验信息""",
    "aggressive": """策略风格（激进）：
- 有人对跳预言家时先判断：是狼人在混淆视听，还是村民在替你挡刀？
- 确认是狼人→硬刚揭穿。可能是村民挡刀→保持沉默配合他
- 第2轮起用完整查验链证明身份
- 第1轮就可以暗示有信息
- 查到的所有结果立刻公布，不给狼人冒充的机会""",
}

WITCH_STRATEGY = {
    "conservative": """策略风格（保守）：
- 永远不暴露自己是女巫
- 只做普通村民的逻辑分析
- 即使被投票也不跳身份
- 投票时低调随大流""",
    "balanced": """策略风格（均衡）：
- 有用药信息就果断跳出来说明
- 局势不明朗时也应主动提供信息引导好人方向
- 被怀疑时跳身份自证清白
- 没有用药信息时积极分析发言""",
    "aggressive": """策略风格（激进）：
- 用药立刻公开宣布
